---
import Sidebar from "../components/Sidebar.tsx";
import Header from "../components/Header.tsx";
import ImageGrid from "../components/ImageGrid.tsx";
import ScanProgress from "../components/ScanProgress.tsx";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Library Web Viewer</title>
  </head>

  <body class="bg-zinc-50 dark:bg-zinc-950 text-zinc-900 dark:text-zinc-100 overflow-hidden h-screen w-full flex transition-colors duration-200">
    {/* Sidebar is fixed width or flex item */}
    <Sidebar client:load />

    <main
      class="flex-1 flex flex-col h-full relative transition-all duration-300 overflow-hidden"
    >
      <Header client:load />

      <div
        class="flex-1 overflow-y-auto custom-scrollbar bg-white dark:bg-zinc-900 transition-colors duration-200"
      >
        <ImageGrid client:load />
      </div>
    </main>

    <ScanProgress client:load />

  </body>
</html>
